"""
Diagnostic visualizations for the ECG digitization pipeline.

Usage
-----
from debug import show_chop, show_extraction, show_grid_detection

show_chop(pil_image)               # are the 12 lead blocks sliced correctly?
show_extraction(pil_image)         # is the red trace following the signal?
show_grid_detection(pil_image)     # is the grid period detected correctly?
"""

import cv2
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import numpy as np
from PIL import Image
from scipy.signal import find_peaks

from extract import (
    LEAD_GRID,
    LEAD_SAMPLES,
    STANDARD_W,
    chop_leads,
    compute_calibration,
    detect_grid_spacing,
    extract_column_signal,
    highpass_filter,
    lowpass_filter,
    standardize,
    vectorise,
)


def show_chop(
    pil_image: Image.Image,
    header_frac: float = 0.08,
    cal_frac: float = 0.03,
    binarize: str = "color",
) -> plt.Figure:
    """
    Shows the standardized binary image with the grid cut lines overlaid,
    and each individual lead block alongside it.
    """
    binary = standardize(pil_image, binarize=binarize)
    n_rows, n_cols = len(LEAD_GRID), len(LEAD_GRID[0])

    H, W = binary.shape
    header_px = int(H * header_frac)
    usable_h = H - header_px
    row_h = usable_h // n_rows
    col_w = W // n_cols

    fig, axes = plt.subplots(
        n_rows,
        n_cols + 1,
        figsize=(4 * (n_cols + 1), 3 * n_rows),
        gridspec_kw={"width_ratios": [2] + [1] * n_cols},
    )

    colors = plt.cm.tab10.colors

    for r in range(n_rows):
        ax_full = axes[r][0]
        ax_full.imshow(binary, cmap="gray", aspect="auto")

        ax_full.axhline(
            header_px, color="yellow", lw=1.2, linestyle="--", label="header"
        )

        for ri in range(1, n_rows):
            ax_full.axhline(header_px + ri * row_h, color="red", lw=1.0, linestyle="-")

        for ci in range(1, n_cols):
            ax_full.axvline(ci * col_w, color="cyan", lw=1.0, linestyle="-")

        y0 = header_px + r * row_h
        rect = mpatches.Rectangle(
            (0, y0),
            W,
            row_h,
            linewidth=2,
            edgecolor=colors[r],
            facecolor=colors[r],
            alpha=0.12,
        )
        ax_full.add_patch(rect)
        ax_full.set_title(f"Row {r}  (red=row cuts, cyan=col cuts)", fontsize=7)
        ax_full.axis("off")

        blocks = chop_leads(binary, header_frac=header_frac, cal_frac=cal_frac)
        for c, name in enumerate(LEAD_GRID[r]):
            ax = axes[r][c + 1]
            ax.imshow(blocks[name], cmap="gray", aspect="auto")
            ax.set_title(
                f"{name}\n{blocks[name].shape[1]}×{blocks[name].shape[0]}", fontsize=8
            )
            ax.axis("off")

    fig.suptitle(
        f"Chop diagnostic  |  header_frac={header_frac}",
        fontsize=10,
    )
    fig.tight_layout()
    return fig


def show_extraction(
    pil_image: Image.Image,
    header_frac: float = 0.08,
    cal_frac: float = 0.03,
    hp_cutoff: float | None = 0.5,
    lp_cutoff: float | None = 40.0,
    binarize: str = "color",
    extract_method: str = "mean",
) -> plt.Figure:
    """
    Overlays the extracted signal on each lead block image.

    The red line shows the raw signal from column extraction.
    If hp_cutoff or lp_cutoff is set, a blue line shows the filtered signal.
    """
    binary = standardize(pil_image, binarize=binarize)
    blocks = chop_leads(binary, header_frac=header_frac, cal_frac=cal_frac)

    _, mV_per_pixel = compute_calibration(blocks)

    apply_filter = hp_cutoff is not None or lp_cutoff is not None

    n_rows, n_cols = len(LEAD_GRID), len(LEAD_GRID[0])
    fig, axes = plt.subplots(
        n_rows,
        n_cols,
        figsize=(5 * n_cols, 3 * n_rows),
        squeeze=False,
    )

    for r, row_names in enumerate(LEAD_GRID):
        for c, name in enumerate(row_names):
            ax = axes[r][c]
            block = blocks[name]
            raw_y = extract_column_signal(block, method=extract_method)

            ax.imshow(block, cmap="gray", aspect="auto", interpolation="nearest")
            ax.plot(np.arange(len(raw_y)), raw_y, color="red", lw=0.9, label="raw")

            if apply_filter:
                signal_mv = vectorise(raw_y, mV_per_pixel, target_samples=LEAD_SAMPLES)
                if hp_cutoff is not None:
                    signal_mv = highpass_filter(signal_mv, cutoff_hz=hp_cutoff)
                if lp_cutoff is not None:
                    signal_mv = lowpass_filter(signal_mv, cutoff_hz=lp_cutoff)
                # Scale filtered mV back to pixel-Y space for overlay
                if mV_per_pixel != 0:
                    baseline_y = float(np.mean(raw_y))
                    filtered_y = baseline_y - signal_mv / mV_per_pixel
                    filt_x = np.linspace(0, len(raw_y) - 1, len(filtered_y))
                    ax.plot(
                        filt_x,
                        filtered_y,
                        color="blue",
                        lw=0.9,
                        alpha=0.7,
                        label="filtered",
                    )

            title = f"{name}  ({block.shape[1]} cols)"
            if apply_filter:
                parts = []
                if hp_cutoff is not None:
                    parts.append(f"HP {hp_cutoff} Hz")
                if lp_cutoff is not None:
                    parts.append(f"LP {lp_cutoff} Hz")
                title += f"\n{' / '.join(parts)}"
            ax.set_title(title, fontsize=8)
            ax.axis("off")

    legend_text = "red=raw" + ("  blue=filtered" if apply_filter else "")
    fig.suptitle(
        f"Extraction diagnostic — {legend_text}",
        fontsize=10,
    )
    fig.tight_layout()
    return fig


def show_grid_detection(pil_image: Image.Image) -> plt.Figure:
    """
    Shows the autocorrelation profiles used by detect_grid_spacing() with
    detected peaks marked as red crosses.
    """
    img_np = np.array(pil_image)
    gray = cv2.cvtColor(img_np, cv2.COLOR_RGB2GRAY) if img_np.ndim == 3 else img_np

    axis_labels = [
        "Column mean  (catches vertical / time-axis grid lines)",
        "Row mean  (catches horizontal / amplitude-axis grid lines)",
    ]
    profiles_raw = [gray.mean(axis=0), gray.mean(axis=1)]

    fig, axes = plt.subplots(2, 2, figsize=(18, 8))

    for row, (profile_raw, label) in enumerate(zip(profiles_raw, axis_labels)):
        profile = profile_raw.astype(float)
        profile -= profile.mean()

        autocorr = np.correlate(profile, profile, mode="full")
        autocorr = autocorr[len(autocorr) // 2 :]
        if autocorr[0] != 0:
            autocorr /= autocorr[0]

        peaks, _ = find_peaks(autocorr, distance=3, height=0.05)

        axes[row][0].plot(profile_raw, lw=0.5, color="steelblue")
        axes[row][0].set_title(label, fontsize=8)
        axes[row][0].set_xlabel("Position (px)", fontsize=8)
        axes[row][0].set_ylabel("Mean intensity", fontsize=8)
        axes[row][0].tick_params(labelsize=7)

        view = min(600, len(autocorr))
        axes[row][1].plot(autocorr[:view], lw=0.6, color="steelblue")

        visible = peaks[peaks < view]
        if len(visible):
            axes[row][1].plot(
                visible,
                autocorr[visible],
                "rx",
                ms=6,
                markeredgewidth=1.5,
                label="peaks",
            )
            period = float(np.median(np.diff(peaks[:10])))
            ppm = period / 5 if period > 24 else period
            axes[row][1].set_title(
                f"Autocorr  |  raw period: {period:.1f} px  →  {ppm:.2f} px/mm",
                fontsize=8,
            )
            axes[row][1].legend(fontsize=7)
        else:
            axes[row][1].set_title("Autocorr  |  no peaks found", fontsize=8)

        axes[row][1].set_xlabel("Lag (px)", fontsize=8)
        axes[row][1].set_ylabel("Normalised autocorrelation", fontsize=8)
        axes[row][1].set_xlim(0, view)
        axes[row][1].tick_params(labelsize=7)

    ppm = detect_grid_spacing(pil_image)
    if ppm is not None:
        scale = STANDARD_W / pil_image.width
        ppm_std = ppm * scale
        px_per_mv = ppm_std * 10.0
        result = f"pixels_per_mm (original) = {ppm:.2f}  →  pixels_per_mV (standardized) = {px_per_mv:.1f}"
    else:
        px_per_mv = (STANDARD_W / 297.0) * 10.0
        result = f"detection failed — fallback pixels_per_mV = {px_per_mv:.1f} (A4 assumption)"

    fig.suptitle(f"Grid detection  |  {result}", fontsize=9)
    fig.tight_layout()
    return fig
